# Google Service Account credentials
# Create a service account in Google Cloud Console, enable Drive and Sheets APIs,
# and share your target Sheet and Drive folder with the service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Google Sheet ID (from the URL: .../spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-sheet-id-here

# Google Drive folder ID (from the folder URL: .../folders/FOLDER_ID)
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here

# Resend API key (resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Optional: verified "from" email address in Resend (defaults to onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=applications@yourdomain.com

# Note: Vercel Hobby plan limits function payloads to 4.5 MB.
# For 10 MB PDFs, use Vercel Pro or a custom server.
